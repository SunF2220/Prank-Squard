; Engine configuration file.
; Godot 4.3+ project file for Prank Squad - Stick Figure Fighting Game
; Core engine implemented in C++ GDExtension, UI/flow in GDScript

[application]
config/name="Prank Squad"
config/description="A Little Fighter 2 inspired stick figure fighting game with C++ GDExtension core"

[rendering]
renderer/rendering_method="forward_plus"
renderer/threads/thread_model=1

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/dpi/allow_hidpi=true

[physics]
common/physics_ticks_per_second=60
common/enable_pause_aware_input=true

[input_devices]
pointing/emulate_touch_from_mouse=false

[gui]
common/snap_controls_to_pixels=true
theme/use_hidpi=true

